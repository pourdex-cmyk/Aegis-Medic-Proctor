# ============================================================
# AEGIS MEDIC PROCTOR — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to source control.
# ============================================================

# ---- Supabase -----------------------------------------------
# Get these from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://rfwfyzxzbzjrnhqmekjc.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — server-side only. NEVER expose to client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ---- Anthropic / Claude AI ----------------------------------
# Get your key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ---- App ----------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Used for email links (invite URLs, password reset, etc.)
# Set to your production domain in production.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- Optional: Analytics ------------------------------------
# Vercel Analytics is enabled by default (no key required for Vercel deploys).
# Uncomment to enable PostHog instead:
# NEXT_PUBLIC_POSTHOG_KEY=phc_your-key
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ---- Optional: Storage --------------------------------------
# Supabase Storage is used by default for doctrine document uploads.
# Max upload size in MB (default 50)
MAX_UPLOAD_SIZE_MB=50

# ---- Optional: Email ----------------------------------------
# Supabase handles transactional email by default.
# To use a custom SMTP provider, configure in Supabase Dashboard:
# Project Settings → Auth → SMTP Settings
